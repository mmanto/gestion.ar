# Copiar a .env.dev (desarrollo) o .env.prod (producción) y completar los valores
#
# NOTA: MongoDB y Redis exponen puertos alternativos en el HOST para evitar
# colisiones con servicios locales existentes:
#   MongoDB → host:27018  (interno Docker: mongo:27017)
#   Redis   → host:6380   (interno Docker: redis:6379)

# ── Entorno ───────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true

# ── Base de datos (usar nombres de servicio dentro de Docker) ─────────────────
MONGODB_URI=mongodb://mongo:27017/gestionar_dev
REDIS_URL=redis://redis:6379

# ── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_PATH=/app/chroma_db

# ── Claude / Anthropic ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-xxx
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ── WhatsApp Business API ─────────────────────────────────────────────────────
WHATSAPP_TOKEN=your_token_here
WHATSAPP_PHONE_ID=your_phone_id
WEBHOOK_VERIFY_TOKEN=your_verify_token_here

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_FROM_BOTFATHER
TELEGRAM_WEBHOOK_SECRET=your_secret_token_here

# ── PWA / VAPID ───────────────────────────────────────────────────────────────
# Generar con: scripts/generarte_vapid_keys.sh
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_SUBJECT=mailto:admin@yourdomain.com

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_minimum_32_chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
